{
  "name": "arweave-bridge",
  "private": true,
  "type": "module",
  "dependencies": {
    "@dha-team/arbundles": "^1.0.4",
    "@permaweb/aoconnect": "^0.0.93",
    "arweave": "^1.15.0"
  },
  "devDependencies": {
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.25.0"
  },
  "scripts": {
    "arweave_bridge:build": "cd arweave_bridge && vite build",
    "create_archive": "node scripts/create-code-archive.mjs",
    "deploy": "node scripts/deploy.mjs --target=both --apk-path=\"build\\app\\outputs\\apk\\release\\app-release.apk\"",
    "deploy:apk": "node scripts/deploy.mjs --target=apk --apk-path=\"build\\app\\outputs\\apk\\release\\app-release.apk\"",
    "deploy:archive": "node scripts/deploy.mjs --target=code",
    "deploy:ship": "node scripts/create-code-archive.mjs && flutter build apk --release && npm run deploy",
    "deploy:ship:apk": "flutter build apk --release && npm run deploy:apk",
    "deploy:ship:archive": "node scripts/create-code-archive.mjs && npm run deploy:archive",
    "build:app": "flutter build apk --release",
    "wallet:new": "node scripts/generate-wallet.mjs"
  }
}
